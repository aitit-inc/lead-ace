# Copy this file to .dev.vars for local development.
# wrangler dev reads it automatically. Both API and MCP workers share this file.

# --- API Worker ---
# Run `npx supabase status` to get the DB URL
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# --- MCP Worker ---
WEB_API_URL="http://localhost:8787"

# --- Shared (both workers) ---
# Run `npx supabase status` to get the JWT secret and keys
SUPABASE_JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"
ENVIRONMENT="development"
