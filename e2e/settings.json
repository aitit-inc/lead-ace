{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__api__*",
      "Bash(curl *)",
      "Bash(jq *)",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "dontAsk"
  }
}
